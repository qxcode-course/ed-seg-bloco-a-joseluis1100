            "content": "package main\nimport \"fmt\"\n\nfunc calcular(n int) {\n    if n == 1 {\n        fmt.Println(\"1^2 = 1\")\n        return\n    }\n    fmt.Printf(\"%d^2 = %d^2 + 2*%d + 1 = ?\\n\", n, n-1, n-1)\n    calcular(n-1)\n}\n\nfunc reverso(i, n int) {\n    if i == n + 1 {\n        return\n    }\n    fmt.Printf(\"%d^2 = %d^2 + 2*%d + 1 = %d\\n\", i, i-1, i-1, i * i)\n    reverso(i+1, n)\n}\n\nfunc main() {\n    var n int\n    fmt.Scan(&n)\n    calcular(n)\n    reverso(2, n)\n}\n",
